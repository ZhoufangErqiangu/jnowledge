{
  "name": "jnowledge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --parallel --filter @jnowledge/server --filter @jnowledge/web dev",
    "dev:server": "pnpm --filter @jnowledge/server dev",
    "dev:web": "pnpm --filter @jnowledge/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,vue,json,md,less}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,json,md,less}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^9.1.0",
    "openapi-types": "^12.1.3",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.38.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "^4.0.0"
    }
  }
}
