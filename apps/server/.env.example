# 复制为 .env 后按需修改。配置经 src/config 的 zod 校验，缺项启动即报错。

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres（对应 docker-compose）
DATABASE_URL=postgres://jnowledge:jnowledge@localhost:5432/jnowledge

# JWT（HS256 单密钥，至少 16 位）
JWT_SECRET=dev-secret-change-me-please
JWT_TTL_SECONDS=604800
# bcrypt 工作因子（纯 JS，慢是故意的安全特性）
BCRYPT_COST=12
# 注册验证码（一期固定码）
REGISTER_CAPTCHA=123456

# 对象存储（MinIO，对应 docker-compose）
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=jnowledge
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_FORCE_PATH_STYLE=true

# LLM —— 路由表（providers/models/tiers/embedding/rerank）在 config.json，这里只放密钥。
# 换环境用 LLM_CONFIG_PATH 指向另一个文件（留空=默认 apps/server/config.json）。
# 密钥读哪个变量由 config.json 各项的 apiKeyEnv 字段控制；下面的键名须与之对应。
LLM_CONFIG_PATH=
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
