# 复制为 .env 后按需修改。配置经 src/config 的 zod 校验，缺项启动即报错。

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres（对应 docker-compose）
DATABASE_URL=postgres://jnowledge:jnowledge@localhost:5432/jnowledge

# JWT（HS256 单密钥，至少 16 位）
JWT_SECRET=dev-secret-change-me-please
JWT_TTL_SECONDS=604800
# bcrypt 工作因子（纯 JS，慢是故意的安全特性）
BCRYPT_COST=12
# 注册验证码（一期固定码）
REGISTER_CAPTCHA=123456

# 对象存储（MinIO，对应 docker-compose）
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=jnowledge
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_FORCE_PATH_STYLE=true

# LLM —— 二期分两侧供应商（留空则对应能力为未配置态；一期 CRUD 闭环不依赖）。
# chat/生成 = DeepSeek（OpenAI 兼容）。tier→模型：heavy=pro，其余=flash。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# tier→模型可覆盖（留空用默认）
LLM_MODEL_HEAVY=deepseek-v4-pro
LLM_MODEL_STANDARD=deepseek-v4-flash
LLM_MODEL_LIGHT=deepseek-v4-flash
LLM_MODEL_NANO=deepseek-v4-flash
# thinking 开关在请求体里的字段名（DeepSeek v4 混合模型，按官方 doc 确认；默认 thinking）
DEEPSEEK_THINKING_FIELD=thinking

# embedding + rerank = SiliconFlow（硅基流动，一个 key，OpenAI 兼容 + Jina 形状 rerank）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
RERANK_MODEL=BAAI/bge-reranker-v2-m3
