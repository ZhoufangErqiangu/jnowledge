{
  "name": "@jnowledge/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": "./src/main.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "embed:backfill": "tsx src/scripts/backfillEmbeddings.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.1",
    "@jnowledge/shared": "workspace:*",
    "@koa/bodyparser": "^5.1.1",
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^3.0.2",
    "@koa/router": "^13.1.0",
    "@liuhlightning/bcrypt": "^0.0.1",
    "@liuhlightning/jwt": "^0.3.6",
    "file-type": "^19.6.0",
    "gpt-tokenizer": "^2.8.1",
    "kysely": "^0.27.5",
    "koa": "^2.15.4",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.6",
    "pino": "^9.6.0",
    "swagger-ui-dist": "^5.18.2",
    "turndown": "^7.2.0",
    "uuidv7": "^1.0.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.11",
    "@types/swagger-ui-dist": "^3.30.5",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.2"
  }
}
